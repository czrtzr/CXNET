# CXNET environment variables.
# Copy this file to .env.local and fill in the values from your Supabase project
# (Supabase dashboard > Project Settings > API). Never commit .env.local.

# Public Supabase config. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL for metadata and OG/preview image links. Optional: on
# Vercel it falls back to the production domain automatically, and to
# http://localhost:3000 in local dev. Set it to pin a custom domain.
NEXT_PUBLIC_SITE_URL=

# Server only. The service role key bypasses Row Level Security.
# It must never be sent to the client or referenced in a "use client" file.
# Used only by admin server actions and the seed script.
SUPABASE_SERVICE_ROLE_KEY=

# The seeded super admin. Cannot be deleted. Defaults to the value below.
SUPER_ADMIN_EMAIL=feitcarter@gmail.com

# The read-only demo (guest) account. The "Explore the demo" link on the login
# screen signs in with a one-time magic-link token minted by the service role, so
# there is no password to manage. This is only an internal handle and never gets
# mail; the default below is fine. Run: node --env-file=.env.local scripts/seed-demo.mjs
DEMO_EMAIL=demo@cxnet.app
